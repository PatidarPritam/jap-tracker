# ---- Server ----
PORT=5001
NODE_ENV=development
# Set to 1 when running behind a reverse proxy so client IPs (used by the
# login rate limiter) are read from X-Forwarded-For.
# TRUST_PROXY=1

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://user:password@host:5432/japtracker

# ---- Auth ----
# REQUIRED in production. Must be a long, random, unique string.
# The app refuses to start in production with a missing/default secret.
JWT_SECRET=change-me-to-a-long-random-string

# ---- Admin login ----
ADMIN_EMAIL=admin@japtracker.local
# Production: provide a bcrypt hash (never a plaintext password). Generate with:
#   node -e "console.log(require('bcrypt').hashSync(process.argv[1], 12))" 'your-password'
# ADMIN_PASSWORD_HASH=
# Development-only fallback, ignored when ADMIN_PASSWORD_HASH is set.
# If neither is set, the dev default password is "admin123".
# ADMIN_PASSWORD=admin123

# ---- CORS ----
# Comma-separated list of allowed origins. Strongly recommended in production;
# when unset, all origins are allowed (convenient for local development).
# CORS_ORIGIN=https://japtracker.example.com,https://www.japtracker.example.com
